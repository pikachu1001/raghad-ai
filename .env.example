# OpenAI
OPENAI_API_KEY=

# PostgreSQL — Neon (production + recommended for local)
# Get free DB at https://neon.tech
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Local SQLite alternative (change prisma/schema.prisma provider to "sqlite"):
# DATABASE_URL="file:./dev.db"

# Auth session secret (generate: openssl rand -hex 32)
AUTH_SECRET=change-me-in-production

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin access (email must match registered user)
ADMIN_EMAIL=

# Affiliate APIs (Phase 3 — store real values in Vercel/host env only)
ADMITAD_CLIENT_ID=
ADMITAD_CLIENT_SECRET=
ADMITAD_AUTH_HEADER=
DCM_API_KEY=
DCM_NETWORK_ID=dcm
TRAVELPAYOUTS_API_TOKEN=
